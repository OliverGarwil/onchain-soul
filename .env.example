# OpenAI-compatible API (biography fallback when on-chain LLM fails via /api/biography)
# Copy to .env.local and fill in real values: cp .env.example .env.local

# API base URL (must include /v1 suffix)
OPENAI_BASE_URL=https://your-api-host/v1

# API key
OPENAI_API_KEY=sk-your-key-here

# Optional: model ID; if unset, uses the first model from /models
OPENAI_MODEL=gpt-5.5
